server {
    listen 80;
    root /usr/share/nginx/html;
    index index.html;

    location / {
        try_files $uri $uri/ =404;
    }

    location /blog/ {
        alias /usr/share/nginx/html/blog/;
        index index.html;
    }

    location /nginx_status {
        stub_status;
        access_log off;
        allow all;
    }
    location /metrics {
        default_type text/plain;
        return 200 "nginx_up 1\n";
    }
}
